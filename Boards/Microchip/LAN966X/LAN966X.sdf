                    <config_items>
                        <config_item name="CORESIGHT_AP_INDEX">1</config_item>
                    </config_items>
                    <device_info_items>
                        <device_info_item name="EXCLUDE_FROM_DTSL">False</device_info_item>
                        <device_info_item name="AP_TYPE">AXI-AP</device_info_item>
                        <device_info_item name="ROM_TABLE_BASE_ADDRESS"/>
                        <device_info_item name="AP_VERSION">APv1</device_info_item>
                    </device_info_items>
                </device>
            </dap>
        </scanchain>
        <topology>
            <topology_link master="CSETM" master_interface="0" slave="CSETB" type="ATB"/>
            <topology_link master="Cortex-A7" slave="CSETM" type="CoreTrace"/>
            <topology_link master="Cortex-A7" slave="CSCTI_0" trigger="7" type="CTITrigger"/>
            <topology_link master="CSETM" slave="CSCTI_0" trigger="6" type="CTITrigger"/>
            <topology_link master="CSCTI_1" slave="CSETB" trigger="0" type="CTITrigger"/>
        </topology>
    </platform>
    <extension name="ds">
        <platform_info info_url="" manufacturer="Microchip" title="LAN966X"/>
        <connection address=""/>
        <jtag_clock adaptive="false" autotune_enable="false" speed="2000000"/>
        <scctimeout value="60000"/>
        <debug_activities debug_vehicle="DSTREAM:DSTREAM_ST:DSTREAM_PT:REALVIEW_ICE:ULINKPRO:ULINKPRO_D:ULINK2">
            <debug_activity connection_id="Cortex-A7" name="Cortex-A7" type="SINGLE_CORE">
                <debug_option type="BARE_METAL"/>
                <debug_option type="LINUX_KERNEL"/>
            </debug_activity>
        </debug_activities>
        <debug_vehicle_connections>
            <debug_vehicle_connection>
                <connection_config type="DSTREAM Family" version="">
                    <config_item name="AllowICELatchSysRst">1</config_item>
                    <config_item name="nTRSTHighMode">0</config_item>
                    <config_item name="nTRSTLowMode">0</config_item>
                    <config_item name="nSRSTHighMode">1</config_item>
                    <config_item name="nSRSTLowMode">0</config_item>
                    <config_item name="SWOBaudRate">0</config_item>
                    <config_item name="SWOMode">0</config_item>
                    <config_item name="UseDeprecatedSWJ">0</config_item>
