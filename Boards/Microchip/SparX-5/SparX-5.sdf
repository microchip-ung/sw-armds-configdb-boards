    <extension name="ds">
        <platform_info info_url="" manufacturer="Microchip" title="SparX-5"/>
        <connection address=""/>
        <jtag_clock adaptive="false" autotune_enable="false" speed="10000000"/>
        <scctimeout value="60000"/>
