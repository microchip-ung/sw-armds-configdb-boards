            <topology_link master="CSETM_1" slave="CSCTI_1" trigger="4" type="CTITrigger"/>
        </topology>
        <clusters>
            <cluster devices="Cortex-A53_0:Cortex-A53_1" name="Cortex-A53_SMP_0"/>
        </clusters>
