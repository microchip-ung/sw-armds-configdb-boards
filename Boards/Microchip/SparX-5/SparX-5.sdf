        <topology>
            <topology_link master="Cortex-A53_0" slave="CSCTI_0" trigger="1" type="CTITrigger"/>
            <topology_link master="Cortex-A53_0" slave="CSETM_0" type="CoreTrace"/>
            <topology_link master="CSETM_0" slave="CSCTI_0" trigger="4" type="CTITrigger"/>
            <topology_link master="Cortex-A53_1" slave="CSCTI_1" trigger="1" type="CTITrigger"/>
